# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://raffleprop:password@localhost:5432/raffleprop_dev

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption (BVN / NIN at rest) ─────────────────────────────────────────
# Generate with: openssl rand -hex 32   (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── Paystack ────────────────────────────────────────────────────────────────
# Paystack signs webhooks with the Secret Key directly (no separate webhook secret).
# Use sk_test_xxx in development, sk_live_xxx in production.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Optional: platform-level subaccount fallback (per-campaign overrides this)
PAYSTACK_SUBACCOUNT_CODE=

# ─── Flutterwave ─────────────────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=change_me_set_this_in_flutterwave_dashboard
# Optional: platform-level subaccount fallback (per-campaign overrides this)
FLUTTERWAVE_SUBACCOUNT_ID=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_MEDIA=raffleprop-media
R2_BUCKET_DOCUMENTS=raffleprop-regulatory-docs
# Production: omit R2_ENDPOINT and the SDK will resolve the Cloudflare R2 URL automatically.
# Local dev (MinIO): R2_ENDPOINT=http://localhost:9000
R2_ENDPOINT=http://localhost:9000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Used by the API for transactional emails (ticket confirmation, password reset, etc.)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=RaffleProp <noreply@raffleprop.com>

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used by the queue worker for winner notification emails.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@raffleprop.com

# ─── SMS / OTP (Termii) ──────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=N-Alert

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
# Used to auto-generate skill questions for campaigns.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Draw (Random.org) ───────────────────────────────────────────────────────
# Required only when a campaign uses drawMethod = RANDOM_ORG_VERIFIED.
RANDOM_ORG_API_KEY=your_random_org_api_key

# ─── Sentry ──────────────────────────────────────────────────────────────────
# API (Node/Express project): SENTRY_DSN
# Web (Next.js project):      NEXT_PUBLIC_SENTRY_DSN
# Leave blank to disable — server starts fine without it.
SENTRY_DSN=https://xxxxx@oXXXXXXXXXXXXXXXX.ingest.de.sentry.io/XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXXXXXXXXXXXX.ingest.de.sentry.io/XXXXXXXXXX
SENTRY_ORG=raffleprop-ltd
SENTRY_PROJECT=javascript-nextjs

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
LOG_LEVEL=info
