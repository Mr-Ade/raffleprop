# ─── API ─────────────────────────────────────────────────────────────────────
# URL of the Express backend — used by both server components and client components.
# In production: https://api.raffleprop.com (or whatever your API domain is)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
# Public base URL of the R2 media bucket (no trailing slash).
# In production: https://media.raffleprop.com (or your R2 custom domain / r2.dev URL)
NEXT_PUBLIC_R2_PUBLIC_URL=http://localhost:9000/raffleprop-media

# ─── Site ────────────────────────────────────────────────────────────────────
# Canonical public URL — used for OG meta tags and referral links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
