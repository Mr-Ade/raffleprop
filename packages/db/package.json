{
  "name": "@raffleprop/db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- ts-node --transpile-only src/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "bcryptjs": "^2.4.3",
    "dotenv-cli": "^7.4.2",
    "nanoid": "^3.3.7",
    "prisma": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
